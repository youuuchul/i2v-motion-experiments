# --- copy to .env and fill in ---
# never commit .env (gitignored)

# Hugging Face (model download / private repos)
HF_TOKEN=
HF_HOME=./hf_cache
HUGGINGFACE_HUB_CACHE=./hf_cache

# OpenAI (LLM prompt generation pipeline)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Anthropic (alternative prompt LLM)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Experiment tracking (optional)
WANDB_API_KEY=
WANDB_PROJECT=i2v-motion
WANDB_MODE=online

# Runtime
DEVICE=cuda
TORCH_DTYPE=bfloat16
SEED=42

# Output / cache roots
OUTPUT_DIR=./outputs
RUN_DIR=./experiments/runs

# Streamlit
STREAMLIT_SERVER_PORT=8501

# Docker user mapping (bind-mount outputs/ 권한 정렬)
# `id -u` / `id -g` 결과를 채우면 컨테이너가 호스트 유저와 같은 UID/GID 로 실행됨.
# 비우면 compose 기본값 1000:1000 사용.
UID=
GID=
